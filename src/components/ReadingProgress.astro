---
interface Props {
  targetSelector?: string;
}
const { targetSelector = '.content' } = Astro.props;
---
<div class="reading-progress" aria-hidden="true">
  <div id="reading-progress-bar" class="reading-progress__bar"></div>
</div>

<script define:vars={{ targetSelector }}>
  const bar = document.getElementById('reading-progress-bar');
  const content = document.querySelector(targetSelector);

  function updateProgress() {
    if (!bar || !content) return;
    const rect = content.getBoundingClientRect();
    const contentTop = rect.top + window.scrollY;
    const contentBottom = contentTop + rect.height;
    const start = contentTop;
    const end = Math.max(contentBottom - window.innerHeight, start + 1);
    const progress = Math.min(1, Math.max(0, (window.scrollY - start) / (end - start)));
    bar.style.width = `${progress * 100}%`;
  }

  updateProgress();
  window.addEventListener('scroll', updateProgress, { passive: true });
  window.addEventListener('resize', updateProgress);
</script>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    z-index: 20;
    pointer-events: none;
  }
  .reading-progress__bar {
    height: 100%;
    width: 0%;
    background: var(--signal);
  }
</style>
