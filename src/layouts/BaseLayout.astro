---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import { CATEGORIES, categoryHref, categoryLabel } from '../lib/categories';
import SearchPalette from '../components/SearchPalette.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  additionalFeed?: { href: string; title: string };
  noindex?: boolean;
}

const {
  title,
  description = 'The Duke Post tracks every major tech outlet and surfaces what actually matters, so you get the day\'s real trends without tab-hopping across a dozen news sites.',
  image,
  type = 'website',
  jsonLd,
  additionalFeed,
  noindex = false,
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = image ? new URL(image, Astro.site) : undefined;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isArticlesActive = pathname === '/articles' || (pathname.startsWith('/articles/') && !pathname.startsWith('/articles/category/'));
const isWireActive = pathname === '/wire' || pathname.startsWith('/wire/');
const isNewsletterActive = pathname === '/newsletter' || pathname.startsWith('/newsletter/');
const isSearchActive = pathname === '/search';
const isSubscribeActive = pathname === '/subscribe';
const isAboutActive = pathname === '/about';
const isCategoriesActive = pathname.startsWith('/articles/category/') || pathname.startsWith('/tags') || pathname.startsWith('/authors') || pathname === '/archive' || pathname === '/reading-list';

const siteJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'The Duke Post',
    url: Astro.site?.toString(),
    logo: new URL('/favicon-v3.svg', Astro.site).toString(),
    sameAs: ['https://github.com/tuan-nguyenduc/thedukepost'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'The Duke Post',
    url: Astro.site?.toString(),
    description: 'Original tech reporting plus a curated Wire of headlines from every major outlet, in one feed.',
  },
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];
---
<!doctype html>
<html lang="en">
<head>
  <script is:inline>
    (function () {
      var stored = localStorage.getItem('theme');
      var theme = stored || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon-v3.svg" />
  <link rel="icon" type="image/png" sizes="48x48" href="/icon-48.png" />
  <link rel="icon" type="image/png" sizes="96x96" href="/icon-96.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <link rel="alternate" type="application/rss+xml" title="The Duke Post" href="/rss.xml" />
  {additionalFeed && <link rel="alternate" type="application/rss+xml" title={additionalFeed.title} href={additionalFeed.href} />}
  <title>{title}</title>

  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="The Duke Post" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
  <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

  {siteJsonLd.map((entry) => (
    <script type="application/ld+json" set:html={JSON.stringify(entry)} />
  ))}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <header class="site-header">
    <div class="wrap site-header__inner">
      <a href="/" class="logo">
        <img src="/favicon-v3.svg" alt="" width="32" height="32" class="logo__mark" />
        The Duke<span class="logo__accent">Post</span>
      </a>
      <nav class="site-nav">
        <a href="/articles" aria-current={isArticlesActive ? 'page' : undefined}>Articles</a>
        <details class="nav-dropdown" data-active={isCategoriesActive ? 'true' : undefined}>
          <summary aria-current={isCategoriesActive ? 'true' : undefined}>Categories</summary>
          <div class="nav-dropdown__panel">
            {CATEGORIES.map((category) => (
              <a href={categoryHref(category)} aria-current={pathname === categoryHref(category) ? 'page' : undefined}>{categoryLabel(category)}</a>
            ))}
            <a href="/tags" aria-current={pathname.startsWith('/tags') ? 'page' : undefined}>Tags</a>
            <a href="/authors" aria-current={pathname.startsWith('/authors') ? 'page' : undefined}>Authors</a>
            <a href="/archive" aria-current={pathname === '/archive' ? 'page' : undefined}>Archive</a>
            <a href="/reading-list" aria-current={pathname === '/reading-list' ? 'page' : undefined}>Reading List</a>
          </div>
        </details>
        <a href="/wire" aria-current={isWireActive ? 'page' : undefined}>Wire</a>
        <a href="/newsletter" aria-current={isNewsletterActive ? 'page' : undefined}>Newsletter</a>
        <a href="/search" aria-label="Search" aria-current={isSearchActive ? 'page' : undefined}>Search <kbd class="kbd-hint">⌘K</kbd></a>
        <a href="/subscribe" class="nav-subscribe" aria-current={isSubscribeActive ? 'page' : undefined}>Subscribe</a>
        <a href="/about" aria-current={isAboutActive ? 'page' : undefined}>About</a>
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode">
          <span class="theme-toggle__icon theme-toggle__icon--sun">☀️</span>
          <span class="theme-toggle__icon theme-toggle__icon--moon">🌙</span>
        </button>
      </nav>
    </div>
  </header>

  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="wrap site-footer__inner">
      <p>&copy; {new Date().getFullYear()} The Duke Post. Independent tech coverage.</p>
      <p class="byline">Curated headlines link to original publishers. <a href="/rss.xml">RSS</a> · <a href="https://github.com/tuan-nguyenduc/thedukepost" target="_blank" rel="noopener noreferrer">GitHub</a></p>
    </div>
  </footer>

  <SearchPalette />

  <Analytics />

  <script is:inline>
    document.getElementById('theme-toggle').addEventListener('click', function () {
      var root = document.documentElement;
      var next = root.dataset.theme === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      localStorage.setItem('theme', next);
    });

    document.addEventListener('click', function (event) {
      document.querySelectorAll('.nav-dropdown[open]').forEach(function (details) {
        if (!details.contains(event.target)) {
          details.removeAttribute('open');
        }
      });
    });

    // Reading list: a localStorage-backed save/bookmark list, kept minimal
    // (slug/title/href/etc, no full article body) so any page can render a
    // save toggle without re-fetching content collection data client-side.
    // Delegated at the document level so it works for buttons that don't
    // exist yet at parse time (e.g. cards rendered client-side elsewhere).
    (function () {
      var STORAGE_KEY = 'reading-list';

      function readList() {
        try {
          var raw = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
          return Array.isArray(raw) ? raw : [];
        } catch (e) {
          return [];
        }
      }

      function setSaveState(btn, saved) {
        btn.classList.toggle('is-saved', saved);
        btn.setAttribute('aria-pressed', saved ? 'true' : 'false');
        var label = saved ? 'Remove from reading list' : 'Save to reading list';
        btn.setAttribute('aria-label', label);
        btn.setAttribute('title', label);
      }

      document.addEventListener('DOMContentLoaded', function () {
        var saved = {};
        readList().forEach(function (item) { saved[item.slug] = true; });
        document.querySelectorAll('[data-save-toggle]').forEach(function (btn) {
          setSaveState(btn, !!saved[btn.dataset.saveSlug]);
        });
      });

      document.addEventListener('click', function (event) {
        var btn = event.target.closest('[data-save-toggle]');
        if (!btn) return;
        var slug = btn.dataset.saveSlug;
        var list = readList();
        var existingIndex = list.findIndex(function (item) { return item.slug === slug; });
        var nowSaved;
        if (existingIndex >= 0) {
          list.splice(existingIndex, 1);
          nowSaved = false;
        } else {
          list.push({
            slug: slug,
            title: btn.dataset.saveTitle || '',
            href: btn.dataset.saveHref || '',
            description: btn.dataset.saveDescription || '',
            image: btn.dataset.saveImage || '',
            category: btn.dataset.saveCategory || '',
            pubDate: btn.dataset.savePubDate || '',
            savedAt: Date.now(),
          });
          nowSaved = true;
        }
        localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
        document.querySelectorAll('[data-save-toggle][data-save-slug="' + slug + '"]').forEach(function (el) {
          setSaveState(el, nowSaved);
        });
        document.dispatchEvent(new CustomEvent('readinglist:change'));
      });
    })();
  </script>
</body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -48px;
    left: 12px;
    z-index: 100;
    padding: 10px 18px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    transition: top 0.15s ease;
  }
  .skip-link:focus {
    top: 12px;
  }

  .site-header {
    border-bottom: 2px solid var(--ink);
    background: var(--paper);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 18px;
    padding-bottom: 18px;
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .logo__accent { color: var(--signal); }
  .logo__mark {
    width: 32px;
    height: 32px;
    transition: transform 0.2s ease;
  }
  .logo:hover .logo__mark {
    transform: rotate(-8deg);
  }
  .site-nav {
    display: flex;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .site-nav a {
    padding: 6px 14px;
    border-radius: 999px;
    transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .site-nav a:hover {
    background: var(--ink);
    color: var(--paper);
    transform: rotate(-1deg);
  }
  .site-nav a[aria-current='page'] {
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
  }
  .kbd-hint {
    margin-left: 4px;
    padding: 1px 5px;
    border: 1px solid currentColor;
    border-radius: 4px;
    font-size: 10px;
    opacity: 0.6;
  }
  .nav-subscribe {
    background: var(--signal);
    color: var(--paper);
  }
  .nav-subscribe:hover {
    background: #e00065;
    color: var(--paper);
  }
  .nav-dropdown { position: relative; }
  .nav-dropdown summary {
    display: inline-block;
    list-style: none;
    cursor: pointer;
    padding: 6px 14px;
    border-radius: 999px;
    transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .nav-dropdown summary::-webkit-details-marker { display: none; }
  .nav-dropdown summary:hover,
  .nav-dropdown[open] summary {
    background: var(--ink);
    color: var(--paper);
  }
  .nav-dropdown[data-active='true'] summary {
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
  }
  .nav-dropdown__panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    display: flex;
    flex-direction: column;
    min-width: 160px;
    padding: 8px;
    background: var(--paper);
    border: 2px solid var(--ink);
    border-radius: 14px;
    box-shadow: 5px 5px 0 var(--ink);
    z-index: 20;
  }
  .nav-dropdown__panel a {
    padding: 8px 12px;
    border-radius: 8px;
    text-transform: none;
    letter-spacing: normal;
    font-family: var(--font-body);
    font-size: 14px;
  }
  .nav-dropdown__panel a:hover {
    background: var(--paper-line);
    transform: none;
  }
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border: 2px solid var(--ink);
    border-radius: 50%;
    background: none;
    font-size: 14px;
    line-height: 1;
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .theme-toggle:hover {
    background: var(--ink);
    transform: rotate(-8deg);
  }
  .theme-toggle__icon--moon { display: none; }
  [data-theme='dark'] .theme-toggle__icon--sun { display: none; }
  [data-theme='dark'] .theme-toggle__icon--moon { display: inline; }

  .site-footer {
    border-top: 2px solid var(--ink);
    margin-top: 80px;
    padding: 28px 0 48px;
    color: var(--slate);
    font-size: 14px;
  }
  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  @media print {
    .site-header,
    .site-footer,
    .theme-toggle {
      display: none !important;
    }
  }

  @media (max-width: 640px) {
    .site-header__inner { flex-direction: column; align-items: flex-start; gap: 12px; }
    .site-nav { gap: 18px; }
    .kbd-hint { display: none; }
  }
</style>
