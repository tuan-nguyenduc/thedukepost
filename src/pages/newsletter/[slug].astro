---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import archive from '../../data/digest-archive.json';

export async function getStaticPaths() {
  return archive.issues.map((issue) => ({
    params: { slug: issue.slug },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const dateLabel = new Date(issue.sentAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---
<BaseLayout
  title={`${issue.subject} — The Duke Post`}
  description={`The Wire digest for ${dateLabel} — ${issue.stories.length} top tech ${issue.stories.length === 1 ? 'story' : 'stories'}.`}
>
  <article class="wrap issue">
    <a href="/newsletter" class="eyebrow">Newsletter Archive</a>
    <h1>{issue.subject}</h1>
    <p class="byline">Sent {dateLabel}</p>

    <ul class="stories">
      {issue.stories.map((story) => (
        <li>
          <a href={story.link} target="_blank" rel="noopener noreferrer" class="sticker story">
            <h2>{story.title}</h2>
            <p>{story.summary}</p>
            <span class="story__meta">{story.source}{story.sourceCount > 1 ? ` + ${story.sourceCount - 1} more outlet${story.sourceCount - 1 > 1 ? 's' : ''}` : ''}</span>
          </a>
        </li>
      ))}
    </ul>

    <section class="issue-newsletter">
      <NewsletterForm className="issue-newsletter__form" />
    </section>
  </article>
</BaseLayout>

<style>
  .issue { padding: 48px 24px 80px; max-width: 740px; }
  .issue h1 { font-size: clamp(28px, 4vw, 40px); margin: 14px 0 8px; }

  .stories { list-style: none; margin: 40px 0 0; padding: 0; display: grid; gap: 20px; }
  .stories li { margin: 0; }
  .story { display: block; padding: 24px; }
  .story h2 { font-size: 22px; margin: 0 0 10px; }
  .story p { color: var(--slate); font-size: 16px; margin: 0 0 12px; }
  .story__meta {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--slate);
  }

  .issue-newsletter { margin-top: 56px; }
  .issue-newsletter__form { max-width: none; }
</style>
