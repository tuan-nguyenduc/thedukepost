---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About — The Duke Post">
  <section class="wrap page">
    <h1>About The Duke Post</h1>
    <p>The Duke Post is an independent tech publication: original articles paired with a curated wire of headlines from across the industry.</p>
    <p>Edit this page at <code>src/pages/about.astro</code> to make it your own.</p>
  </section>
</BaseLayout>

<style>
  .page { padding: 48px 24px 80px; max-width: 680px; }
  h1 { font-size: 36px; margin-bottom: 24px; }
  p { font-size: 18px; line-height: 1.7; color: var(--slate); margin: 0 0 16px; }
  code { font-family: var(--font-mono); background: var(--paper-line); padding: 2px 6px; border-radius: 4px; font-size: 15px; }
</style>
