import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="About — The Duke Post"
  description="The Duke Post is an independent tech publication built around one idea: you shouldn't need a dozen open tabs to keep up with tech. Here's how it works."
>
  <section class="wrap page">
    <h1>About The Duke Post</h1>
    <p>The Duke Post is an independent tech publication built around one idea: you shouldn't need a dozen open tabs to know what's actually happening in tech.</p>
    <p>Most people keep up with tech by bouncing between a handful of sites, hoping they didn't miss the one story everyone will be talking about tomorrow. We do that bouncing for you. The Wire continuously pulls headlines from major outlets across the industry into a single, regularly refreshed feed — so the day's real trends surface in one place instead of a dozen.</p>
    <p>Alongside that, we publish original articles: analysis and context on the stories that matter, written by The Duke Post rather than just linked to.</p>
    <p>Every curated headline links straight back to its original publisher — we're not trying to replace the reporting, just save you the trip of finding it.</p>
  </section>
</BaseLayout>

<style>
  .page { padding: 48px 24px 80px; max-width: 680px; }
  h1 { font-size: 36px; margin-bottom: 24px; }
  p { font-size: 18px; line-height: 1.7; color: var(--slate); margin: 0 0 16px; }
</style>
