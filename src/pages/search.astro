---
import BaseLayout from '../layouts/BaseLayout.astro';
import { categoryHref, categoryLabel } from '../lib/categories';
---
<BaseLayout title="Search — The Duke Post" description="Search articles on The Duke Post.">
  <section class="search-page wrap">
    <h1 class="search-title">Search</h1>
    <div class="search-box">
      <input
        id="search-input"
        type="search"
        placeholder="Search articles…"
        autocomplete="off"
        autofocus
        aria-label="Search articles"
      />
    </div>
    <p id="search-status" class="search-status" aria-live="polite"></p>
    <ul id="search-results" class="results-list" role="listbox"></ul>
    <div id="search-empty" class="empty-state sticker" hidden>
      <p class="empty-state__title">No results found</p>
      <p class="empty-state__hint">Try a different search term, or browse <a href="/articles">all articles</a> and <a href="/wire">the Wire</a> instead.</p>
    </div>
  </section>
</BaseLayout>

<script>
  import Fuse from 'fuse.js';

  interface SearchItem {
    type: 'article' | 'wire';
    link: string;
    title: string;
    description: string;
    category: string;
    pubDate: string;
  }

  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsList = document.getElementById('search-results') as HTMLUListElement;
  const status = document.getElementById('search-status') as HTMLParagraphElement;
  const emptyState = document.getElementById('search-empty') as HTMLDivElement;

  let fuse: Fuse<SearchItem> | null = null;
  let activeIndex = -1;
  let currentResults: SearchItem[] = [];

  function escapeHtml(str: string): string {
    return str.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c] as string));
  }

  async function init() {
    const res = await fetch('/search-index.json');
    const items: SearchItem[] = await res.json();
    fuse = new Fuse(items, {
      keys: [
        { name: 'title', weight: 2 },
        { name: 'description', weight: 1 },
        { name: 'category', weight: 0.5 },
      ],
      threshold: 0.4,
      includeMatches: true,
    });

    const params = new URLSearchParams(window.location.search);
    const q = params.get('q') ?? '';
    if (q) {
      input.value = q;
      runSearch(q);
    }
  }

  function categoryLabel(cat: string): string {
    const labels: Record<string, string> = {
      ai: 'AI', gadgets: 'Gadgets', startups: 'Startups',
      security: 'Security', opinion: 'Opinion', general: 'General',
    };
    return labels[cat] ?? cat;
  }

  function setActive(index: number): void {
    const items = resultsList.querySelectorAll('.result-item');
    items.forEach((el) => el.classList.remove('result-item--active'));
    if (index >= 0 && index < items.length) {
      items[index].classList.add('result-item--active');
      items[index].scrollIntoView({ block: 'nearest' });
    }
    activeIndex = index;
  }

  function renderResults(items: SearchItem[], hasQuery: boolean) {
    currentResults = items;
    activeIndex = -1;
    if (items.length === 0) {
      resultsList.innerHTML = '';
      status.textContent = '';
      emptyState.hidden = !hasQuery;
      return;
    }
    emptyState.hidden = true;
    status.textContent = `${items.length} result${items.length === 1 ? '' : 's'}`;
    resultsList.innerHTML = items.map((item, i) => {
      const isWire = item.type === 'wire';
      const eyebrow = escapeHtml(isWire ? `Wire · ${item.category}` : categoryLabel(item.category));
      const linkAttrs = isWire ? ' target="_blank" rel="noopener noreferrer"' : '';
      return `
      <li class="result-item" role="option" data-index="${i}">
        <a href="${escapeHtml(item.link)}" class="result-card sticker"${linkAttrs}>
          <span class="result-meta">
            <span class="eyebrow">${eyebrow}</span>
            <span class="byline">${escapeHtml(item.pubDate)}</span>
          </span>
          <h2 class="result-title">${escapeHtml(item.title)}</h2>
          <p class="result-desc">${escapeHtml(item.description)}</p>
        </a>
      </li>
    `;
    }).join('');
  }

  function runSearch(query: string) {
    if (!fuse) return;
    const q = query.trim();
    if (!q) {
      resultsList.innerHTML = '';
      status.textContent = '';
      emptyState.hidden = true;
      currentResults = [];
      activeIndex = -1;
      return;
    }
    renderResults(fuse.search(q).map((r) => r.item), true);
    const url = new URL(window.location.href);
    url.searchParams.set('q', q);
    window.history.replaceState(null, '', url.toString());
  }

  input.addEventListener('input', () => runSearch(input.value));

  input.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(Math.min(activeIndex + 1, currentResults.length - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(Math.max(activeIndex - 1, 0));
    } else if (e.key === 'Enter') {
      if (activeIndex >= 0 && currentResults[activeIndex]) {
        e.preventDefault();
        const item = currentResults[activeIndex];
        if (item.type === 'wire') {
          window.open(item.link, '_blank', 'noopener,noreferrer');
        } else {
          window.location.href = item.link;
        }
      }
    }
  });

  init();
</script>

<style>
  .search-page {
    padding: 48px 24px 80px;
    max-width: 720px;
  }
  .search-title {
    font-size: clamp(32px, 5vw, 48px);
    margin-bottom: 28px;
  }
  .search-box {
    margin-bottom: 16px;
  }
  #search-input {
    width: 100%;
    padding: 14px 18px;
    font-size: 18px;
    font-family: var(--font-body);
    background: var(--paper);
    color: var(--ink);
    border: 2px solid var(--ink);
    border-radius: 12px;
    box-shadow: 4px 4px 0 var(--ink);
    outline: none;
    transition: box-shadow 0.15s ease;
  }
  #search-input:focus {
    box-shadow: 4px 4px 0 var(--signal);
    border-color: var(--signal);
  }
  .search-status {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--slate);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 24px;
    min-height: 18px;
  }
  .results-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .result-card {
    display: block;
    padding: 22px 24px;
  }
  .result-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }
  .result-title {
    font-size: 22px;
    margin-bottom: 8px;
  }
  .result-desc {
    color: var(--slate);
    font-size: 15px;
    margin: 0;
  }
  .result-item--active .result-card {
    background: var(--accent-soft);
    border-color: var(--accent);
  }

  .empty-state {
    padding: 28px 24px;
    text-align: center;
  }
  .empty-state__title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .empty-state__hint {
    color: var(--slate);
    font-size: 15px;
    margin: 0;
  }
  .empty-state__hint a { color: var(--accent); border-bottom: 2px solid var(--accent-soft); }
  .empty-state__hint a:hover { border-color: var(--accent); }
</style>
