---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import Comments from '../../components/Comments.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import { getCollection, render } from 'astro:content';
import { categoryHref, categoryLabel } from '../../lib/categories';
import { tagHref, tagSlug } from '../../lib/tags';
import { authorHref } from '../../lib/authors';
import { calculateReadingTime, formatReadingTime } from '../../lib/readingTime';
import { getShareUrls } from '../../lib/share';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(article);
const readingTime = calculateReadingTime(article.body);

const articleUrl = new URL(`/articles/${article.slug}`, Astro.site).toString();
const shareUrls = getShareUrls({
  url: articleUrl,
  title: article.data.title,
  description: article.data.description,
});

const allArticles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentIndex = allArticles.findIndex((a) => a.id === article.id);
const newerArticle = currentIndex > 0 ? allArticles[currentIndex - 1] : null;
const olderArticle = currentIndex < allArticles.length - 1 ? allArticles[currentIndex + 1] : null;

const articleTagSlugs = article.data.tags.map(tagSlug);

const relatedArticles = allArticles
  .filter((a) => a.id !== article.id)
  .map((a) => {
    const sharedTags = a.data.tags.filter((t) => articleTagSlugs.includes(tagSlug(t))).length;
    const sameCategory = a.data.category === article.data.category;
    const score = sharedTags * 2 + (sameCategory ? 1 : 0);
    return { article: a, score };
  })
  .filter((r) => r.score > 0)
  .sort((a, b) => b.score - a.score || b.article.data.pubDate.valueOf() - a.article.data.pubDate.valueOf())
  .slice(0, 3)
  .map((r) => r.article);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: article.data.title,
  description: article.data.description,
  datePublished: article.data.pubDate.toISOString(),
  author: { '@type': 'Organization', name: article.data.author },
  publisher: { '@type': 'Organization', name: 'The Duke Post' },
  ...(article.data.image ? { image: [new URL(article.data.image, Astro.site).toString()] } : {}),
};
---
<BaseLayout
  title={`${article.data.title} — The Duke Post`}
  description={article.data.description}
  image={article.data.image ?? `/og/${article.slug}.png`}
  type="article"
  jsonLd={articleJsonLd}
>
  <ReadingProgress />
  <article class="wrap article">
    {article.data.image && <img class="article__hero" src={article.data.image} alt="" />}
    <a href={categoryHref(article.data.category)} class="eyebrow">{categoryLabel(article.data.category)}</a>
    <h1>{article.data.title}</h1>
    <p class="byline"><a href={authorHref(article.data.author)}>{article.data.author}</a> · {article.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} · {formatReadingTime(readingTime)}</p>
    {article.data.tags.length > 0 && (
      <ul class="tags">
        {article.data.tags.map((tag) => (
          <li><a href={tagHref(tag)} class="tag-chip">#{tag}</a></li>
        ))}
      </ul>
    )}
    <TableOfContents headings={headings} />
    <div class="content">
      <Content />
    </div>
    <div class="share">
      <p class="share__label">Share this article</p>
      <div class="share__buttons">
        <a href={shareUrls.twitter} target="_blank" rel="noopener noreferrer" class="share__button share__button--twitter" title="Share on X" aria-label="Share on X">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.514l-5.106-6.694-5.829 6.694h-3.328l7.732-8.835L.424 2.25h6.679l4.882 6.268L17.75 2.25h.494zm-1.38 19.5h1.84L7.114 3.995H5.113L16.864 21.75z"/></svg>
        </a>
        <a href={shareUrls.linkedin} target="_blank" rel="noopener noreferrer" class="share__button share__button--linkedin" title="Share on LinkedIn" aria-label="Share on LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={shareUrls.email} class="share__button share__button--email" title="Share via email" aria-label="Share via email">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </a>
        <button type="button" id="copy-link" class="share__button share__button--copy" data-url={articleUrl} title="Copy link" aria-label="Copy link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.07 0l2.83-2.83a5 5 0 0 0-7.07-7.07l-1.42 1.42"/><path d="M14 11a5 5 0 0 0-7.07 0l-2.83 2.83a5 5 0 0 0 7.07 7.07l1.42-1.42"/></svg>
        </button>
        <button type="button" id="print-article" class="share__button share__button--print" title="Print article" aria-label="Print article">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v8H6z"/></svg>
        </button>
      </div>
    </div>

    {(newerArticle || olderArticle) && (
      <nav class="article-pager" aria-label="Article navigation">
        {newerArticle ? (
          <a href={`/articles/${newerArticle.slug}`} class="article-pager__link article-pager__link--newer">
            <span class="article-pager__dir">← Newer</span>
            <span class="article-pager__title">{newerArticle.data.title}</span>
          </a>
        ) : <span />}
        {olderArticle ? (
          <a href={`/articles/${olderArticle.slug}`} class="article-pager__link article-pager__link--older">
            <span class="article-pager__dir">Older →</span>
            <span class="article-pager__title">{olderArticle.data.title}</span>
          </a>
        ) : <span />}
      </nav>
    )}

    <Comments />

    <section class="article-newsletter">
      <NewsletterForm className="article-newsletter__form" />
    </section>
  </article>

  <script>
    const copyBtn = document.getElementById('copy-link');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const url = copyBtn.getAttribute('data-url') || window.location.href;
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          const input = document.createElement('input');
          input.value = url;
          document.body.appendChild(input);
          input.select();
          document.execCommand('copy');
          document.body.removeChild(input);
        }
        copyBtn.classList.add('share__button--copied');
        copyBtn.setAttribute('aria-label', 'Link copied');
        window.setTimeout(() => {
          copyBtn.classList.remove('share__button--copied');
          copyBtn.setAttribute('aria-label', 'Copy link');
        }, 2000);
      });
    }

    const printBtn = document.getElementById('print-article');
    if (printBtn) {
      printBtn.addEventListener('click', () => window.print());
    }
  </script>

  {relatedArticles.length > 0 && (
    <section class="wrap related">
      <h2>Related articles</h2>
      <ul class="related__list">
        {relatedArticles.map((a) => (
          <li>
            <a href={`/articles/${a.slug}`} class="sticker related__card">
              {a.data.image && <img class="related__image" src={a.data.image} alt="" loading="lazy" />}
              <div class="related__body">
                <h3>{a.data.title}</h3>
                <p>{a.data.description}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

<style>
  .article { padding: 48px 24px 80px; max-width: 740px; }
  .article__hero {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: 16px;
    border: 2px solid var(--ink);
    margin-bottom: 28px;
  }
  .article h1 { font-size: clamp(28px, 4vw, 42px); margin: 10px 0 14px; }
  .tags { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; margin: 16px 0 0; padding: 0; }
  .tag-chip {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--slate);
    background: var(--paper-line);
    border-radius: 999px;
    padding: 4px 12px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tag-chip:hover { background: var(--accent-soft); color: var(--ink); }
  .content { margin-top: 36px; font-size: 18px; line-height: 1.7; }
  .content :global(h2) { font-size: 24px; margin: 36px 0 14px; }
  .content :global(p) { margin: 0 0 20px; }
  .content :global(a) { color: var(--accent); border-bottom: 2px solid var(--accent-soft); transition: border-color 0.15s ease; }
  .content :global(a:hover) { border-color: var(--accent); }
  .content :global(ol),
  .content :global(ul) { padding-left: 22px; margin: 0 0 20px; }

  .article-pager {
    margin-top: 48px;
    padding-top: 28px;
    border-top: 2px solid var(--paper-line);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .article-pager__link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 18px;
    border: 2px solid var(--ink);
    border-radius: 12px;
    min-width: 0;
    transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .article-pager__link:hover { background: var(--ink); color: var(--paper); transform: rotate(-1deg); }
  .article-pager__link--older { text-align: right; align-items: flex-end; grid-column: 2; }
  .article-pager__dir {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--slate);
  }
  .article-pager__link:hover .article-pager__dir { color: inherit; opacity: 0.75; }
  .article-pager__title { font-size: 16px; font-weight: 600; overflow-wrap: anywhere; }

  @media (max-width: 560px) {
    .article-pager { grid-template-columns: 1fr; }
    .article-pager__link--older { grid-column: 1; text-align: left; align-items: flex-start; }
  }

  .share { margin-top: 48px; padding-top: 28px; border-top: 2px solid var(--paper-line); }
  .share__label { font-size: 13px; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.03em; color: var(--slate); margin: 0 0 14px; }
  .share__buttons { display: flex; gap: 12px; }

  .article-newsletter { margin-top: 56px; }
  .article-newsletter__form { max-width: none; }
  .share__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 2px solid var(--ink);
    border-radius: 8px;
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .share__button svg { width: 24px; height: 24px; }
  .share__button:hover { transform: rotate(-2deg); }
  .share__button--twitter:hover { background: #1DA1F2; border-color: #1DA1F2; color: white; }
  .share__button--linkedin:hover { background: #0A66C2; border-color: #0A66C2; color: white; }
  .share__button--email:hover { background: var(--accent); border-color: var(--accent); color: var(--paper); }
  .share__button--copy,
  .share__button--print { cursor: pointer; }
  .share__button--copy:hover,
  .share__button--print:hover { background: var(--accent); border-color: var(--accent); color: var(--paper); }
  .share__button--copied { background: var(--signal); border-color: var(--signal); color: var(--ink-fixed); }

  .related { padding: 56px 24px 80px; max-width: 740px; }
  .related h2 { font-size: 24px; margin-bottom: 28px; }
  .related__list { list-style: none; margin: 0; padding: 0; display: grid; gap: 20px; }
  .related__card { display: flex; gap: 16px; align-items: flex-start; padding: 18px; }
  .related__image {
    width: 100px;
    height: 70px;
    object-fit: cover;
    border-radius: 8px;
    border: 2px solid var(--ink);
    flex-shrink: 0;
  }
  .related__body { flex: 1; min-width: 0; }
  .related__body h3 { font-size: 18px; margin: 0 0 6px; overflow-wrap: anywhere; }
  .related__body p { font-size: 14px; color: var(--slate); margin: 0; overflow-wrap: anywhere; }

  @media (max-width: 560px) {
    .related__card { flex-direction: column; gap: 12px; }
    .related__image { width: 100%; height: 120px; }
  }

  @media print {
    .share,
    .article-newsletter,
    .article-pager,
    .related,
    :global(.reading-progress),
    :global(.toc),
    :global(.comments) {
      display: none !important;
    }
    .content :global(a) { color: inherit; border-bottom: none; }
  }
</style>
