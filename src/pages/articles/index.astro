---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Articles — The Duke Post">
  <section class="wrap page">
    <h1>Articles</h1>
    {articles.length > 0 ? (
      <ul class="list">
        {articles.map((a) => (
          <li>
            <a href={`/articles/${a.slug}`} class="sticker">
              <span class="eyebrow">{a.data.category}</span>
              <h2>{a.data.title}</h2>
              <p>{a.data.description}</p>
              <span class="byline">{a.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No articles published yet — check back soon.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page { padding: 48px 24px 80px; }
  h1 { font-size: 36px; margin-bottom: 36px; }
  .list { list-style: none; margin: 0; padding: 0; display: grid; gap: 24px; }
  .list li { margin: 0; min-width: 0; }
  .list a { display: block; padding: 24px; }
  .list h2 { font-size: 24px; margin: 12px 0 8px; overflow-wrap: anywhere; }
  .list p { color: var(--slate); margin: 0 0 8px; overflow-wrap: anywhere; }
  .empty { color: var(--slate); font-size: 17px; }
</style>
