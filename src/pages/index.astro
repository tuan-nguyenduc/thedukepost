---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import wireData from '../data/wire.json';
import { faviconUrl } from '../lib/favicon';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = articles.find((a) => a.data.featured) ?? articles[0];
const rest = articles.filter((a) => a.id !== featured?.id).slice(0, 4);

const wireItems = wireData.items.slice(0, 10);
const syncedAt = new Date(wireData.syncedAt);
---
<BaseLayout title="The Duke Post — Tech News & Signal">
  {featured && (
    <section class="hero wrap">
      <a href={`/articles/${featured.slug}`} class="hero__link sticker">
        <span class="eyebrow">{featured.data.category}</span>
        <h1 class="hero__title">{featured.data.title}</h1>
        <p class="hero__desc">{featured.data.description}</p>
        <span class="byline">{featured.data.author} · {featured.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
      </a>
    </section>
  )}

  {rest.length > 0 && (
    <section class="more-articles wrap">
      <h2 class="section-title">Fresh off the desk</h2>
      <div class="more-grid">
        {rest.map((a) => (
          <a href={`/articles/${a.slug}`} class="more-card sticker">
            <span class="eyebrow">{a.data.category}</span>
            <h3>{a.data.title}</h3>
            <p>{a.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="wire wrap">
    <div class="wire__header">
      <h2 class="section-title">⚡ The Wire</h2>
      <span class="wire__synced">last synced {syncedAt.toISOString().replace('T', ' ').slice(0, 16)} UTC</span>
    </div>
    <ul class="wire__list">
      {wireItems.map((item) => (
        <li class="wire__item">
          <a href={item.link} target="_blank" rel="noopener noreferrer">
            <span class="wire__source">
              {faviconUrl(item.link) && <img class="wire__logo" src={faviconUrl(item.link)} alt="" width="14" height="14" loading="lazy" />}
              {item.source}
            </span>
            <span class="wire__title">{item.title}</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="wire__note">Headlines link directly to their original publishers. See <a href="/wire">the full Wire archive</a>.</p>
  </section>
</BaseLayout>

<style>
  .hero { padding: 48px 24px; }
  .hero__link { display: block; padding: 40px 36px; }
  .hero__title {
    font-size: clamp(32px, 5vw, 56px);
    margin-top: 14px;
    max-width: 16ch;
  }
  .hero__desc {
    font-size: 19px;
    color: var(--slate);
    max-width: 60ch;
    margin: 18px 0 14px;
    font-family: var(--font-display);
    font-weight: 500;
  }

  .section-title {
    font-size: 22px;
    margin-bottom: 22px;
  }

  .more-articles { padding: 24px 24px 56px; }
  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 28px;
  }
  .more-card { display: block; padding: 22px; }
  .more-card h3 {
    font-size: 19px;
    margin: 12px 0 8px;
  }
  .more-card p {
    color: var(--slate);
    font-size: 15px;
    margin: 0;
  }

  .wire {
    background: var(--surface);
    color: var(--surface-text);
    padding: 48px 24px 56px;
    border-radius: 24px;
    margin: 0 auto 56px;
  }
  .wire .section-title { color: var(--surface-text); }
  .wire__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 10px;
  }
  .wire__synced {
    font-family: var(--font-mono);
    font-size: 12px;
    color: #8B96A5;
  }
  .wire__list {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    border-top: 1px solid var(--surface-line);
  }
  .wire__item {
    border-bottom: 1px solid var(--surface-line);
  }
  .wire__item a {
    display: flex;
    gap: 16px;
    align-items: baseline;
    padding: 13px 0;
  }
  .wire__source {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--signal);
    flex-shrink: 0;
    width: 140px;
  }
  .wire__logo {
    border-radius: 3px;
    flex-shrink: 0;
  }
  .wire__title {
    font-size: 15px;
    transition: color 0.15s ease;
  }
  .wire__item a:hover .wire__title { color: var(--accent-soft); }
  .wire__note {
    font-size: 13px;
    color: #8B96A5;
    margin-top: 22px;
  }
  .wire__note a { color: var(--surface-text); border-bottom: 1px solid var(--signal); }

  @media (max-width: 640px) {
    .wire__item a { flex-direction: column; gap: 4px; }
    .wire__source { width: auto; }
  }
</style>
