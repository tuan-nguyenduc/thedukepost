---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';
import wireData from '../data/wire.json';
import { faviconUrl } from '../lib/favicon';
import { categoryHref, categoryLabel } from '../lib/categories';
import { calculateReadingTime, formatReadingTime } from '../lib/readingTime';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const GRID_SIZE = 8;

const featured = articles.find((a) => a.data.featured) ?? articles[0];
const rest = articles.filter((a) => a.id !== featured?.id).slice(0, GRID_SIZE);

const wireItems = wireData.items.slice(0, 10);
const syncedAt = new Date(wireData.syncedAt);

// Backfill the grid with Wire highlights when there aren't enough original
// articles yet, so the homepage isn't sparse. Pull from items past the ones
// already shown in the Wire section below, to avoid duplicates on the page.
const fillCount = Math.max(0, GRID_SIZE - rest.length);
const wireFill = wireData.items.slice(10, 10 + fillCount);

const moreCards = [
  ...rest.map((a) => ({ kind: 'article' as const, article: a })),
  ...wireFill.map((item) => ({ kind: 'wire' as const, item })),
];
---
<BaseLayout
  title="The Duke Post — All the Tech Trends, One Feed, No Tab-Hopping"
  description="The Duke Post tracks every major tech outlet so you don't have to. Original reporting plus a constantly updated Wire of curated headlines — the day's real trends in one place."
  image={featured?.data.image}
>
  <p class="tagline wrap">Skip the dozen open tabs. Original reporting and a live, curated Wire from every major outlet — the trends that matter, in one feed.</p>
  {featured && (
    <section class="hero wrap">
      <div class="hero__card">
        <a href={`/articles/${featured.slug}`} class="hero__link sticker">
          {featured.data.image && <img class="hero__image" src={featured.data.image} alt="" />}
          <h1 class="hero__title">{featured.data.title}</h1>
          <p class="hero__desc">{featured.data.description}</p>
          <span class="byline">{featured.data.author} · {featured.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
        </a>
        <a href={categoryHref(featured.data.category)} class="eyebrow hero__eyebrow">{categoryLabel(featured.data.category)}</a>
      </div>
    </section>
  )}

  {moreCards.length > 0 && (
    <section class="more-articles wrap">
      <h2 class="section-title">Fresh off the desk</h2>
      <div class="more-grid">
        {moreCards.map((card) => (
          card.kind === 'article' ? (
            <div class="more-card-wrap">
              <a href={`/articles/${card.article.slug}`} class="more-card sticker">
                {card.article.data.image && <img class="more-card__image" src={card.article.data.image} alt="" loading="lazy" />}
                <h3>{card.article.data.title}</h3>
                <p>{card.article.data.description}</p>
                <span class="more-card__meta">{formatReadingTime(calculateReadingTime(card.article.body))}</span>
              </a>
              <a href={categoryHref(card.article.data.category)} class="eyebrow more-card__eyebrow">{categoryLabel(card.article.data.category)}</a>
            </div>
          ) : (
            <a href={card.item.link} target="_blank" rel="noopener noreferrer" class="more-card more-card--wire sticker">
              <img class="more-card__image" src={card.item.image || '/wire-placeholder.svg'} alt="" loading="lazy" />
              <span class="eyebrow eyebrow--wire">From the Wire · {card.item.source}{card.item.sourceCount > 1 ? ` +${card.item.sourceCount - 1}` : ''}</span>
              <h3>{card.item.title}</h3>
              <p>{card.item.summary}</p>
            </a>
          )
        ))}
      </div>
    </section>
  )}

  <section class="newsletter wrap">
    <NewsletterForm />
  </section>

  <section class="wire wrap">
    <div class="wire__header">
      <h2 class="section-title">⚡ The Wire</h2>
      <span class="wire__synced">last synced {syncedAt.toISOString().replace('T', ' ').slice(0, 16)} UTC</span>
    </div>
    <ul class="wire__list">
      {wireItems.map((item) => (
        <li class="wire__item">
          <a href={item.link} target="_blank" rel="noopener noreferrer">
            <span class="wire__source">
              {faviconUrl(item.link) && <img class="wire__logo" src={faviconUrl(item.link)} alt="" width="14" height="14" loading="lazy" />}
              {item.source}
            </span>
            <span class="wire__title">{item.title}</span>
            {item.sourceCount > 1 && <span class="wire__also">+{item.sourceCount - 1}</span>}
          </a>
        </li>
      ))}
    </ul>
    <p class="wire__note">Headlines link directly to their original publishers. See <a href="/wire">the full Wire archive</a>.</p>
  </section>
</BaseLayout>

<style>
  .tagline {
    padding: 28px 24px 0;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.02em;
    color: var(--slate);
    max-width: 56ch;
  }
  .hero { padding: 48px 24px; }
  .hero__card { position: relative; }
  .hero__eyebrow { position: absolute; top: 28px; left: 28px; z-index: 2; }
  .hero__link { display: block; padding: 40px 36px; }
  .hero__image {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border-radius: 16px;
    border: 2px solid var(--ink);
    margin-bottom: 24px;
  }
  .hero__title {
    font-size: clamp(32px, 5vw, 56px);
    margin-top: 14px;
    max-width: 16ch;
  }
  .hero__desc {
    font-size: 19px;
    color: var(--slate);
    max-width: 60ch;
    margin: 18px 0 14px;
    font-family: var(--font-display);
    font-weight: 500;
  }

  .section-title {
    font-size: 22px;
    margin-bottom: 22px;
  }

  .more-articles { padding: 24px 24px 56px; }

  .newsletter { padding: 48px 24px 24px; }
  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 28px;
  }
  .more-card-wrap { position: relative; min-width: 0; }
  .more-card-wrap > .more-card { height: 100%; }
  .more-card__eyebrow { position: absolute; top: 14px; left: 14px; z-index: 2; }
  .more-card { display: block; padding: 22px; }
  .more-card__image {
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: 10px;
    border: 2px solid var(--ink);
    margin-bottom: 14px;
  }
  .more-card h3 {
    font-size: 19px;
    margin: 0 0 8px;
    overflow-wrap: anywhere;
  }
  .more-card--wire { border-style: dashed; }
  .eyebrow--wire { color: var(--signal); }
  .more-card p {
    color: var(--slate);
    font-size: 15px;
    margin: 0 0 8px;
    overflow-wrap: anywhere;
  }
  .more-card__meta {
    display: block;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--slate);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .wire {
    background: var(--surface);
    color: var(--surface-text);
    padding: 48px 24px 56px;
    border-radius: 24px;
    margin: 0 auto 56px;
  }
  .wire .section-title { color: var(--surface-text); }
  .wire__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 10px;
  }
  .wire__synced {
    font-family: var(--font-mono);
    font-size: 12px;
    color: #8B96A5;
  }
  .wire__list {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    border-top: 1px solid var(--surface-line);
  }
  .wire__item {
    border-bottom: 1px solid var(--surface-line);
  }
  .wire__item a {
    display: flex;
    gap: 16px;
    align-items: baseline;
    padding: 13px 0;
  }
  .wire__source {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--signal);
    flex-shrink: 0;
    width: 140px;
  }
  .wire__logo {
    border-radius: 3px;
    flex-shrink: 0;
  }
  .wire__title {
    font-size: 15px;
    transition: color 0.15s ease;
  }
  .wire__item a:hover .wire__title { color: var(--accent-soft); }
  .wire__also {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-fixed);
    background: var(--signal);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .wire__note {
    font-size: 13px;
    color: #8B96A5;
    margin-top: 22px;
  }
  .wire__note a { color: var(--surface-text); border-bottom: 1px solid var(--signal); }

  @media (max-width: 640px) {
    .wire__item a { flex-direction: column; gap: 4px; }
    .wire__source { width: auto; }
  }
</style>
