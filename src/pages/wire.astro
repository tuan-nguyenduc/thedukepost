---
import BaseLayout from '../layouts/BaseLayout.astro';
import wireData from '../data/wire.json';
import { faviconUrl } from '../lib/favicon';

const syncedAt = new Date(wireData.syncedAt);

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The Wire — The Duke Post',
  description: 'Curated tech headlines from across the industry, refreshed regularly.',
  itemListElement: wireData.items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: item.link,
    name: item.title,
  })),
};
---
<BaseLayout title="The Wire — The Duke Post" description="Curated tech headlines, refreshed regularly.">
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <section class="wrap page">
    <h1>⚡ The Wire</h1>
    <p class="intro">A running feed of headlines from other publishers. We link out — we don't republish. <span class="byline">Last synced {syncedAt.toISOString().replace('T', ' ').slice(0, 16)} UTC</span></p>
    <ul class="list">
      {wireData.items.map((item) => (
        <li>
          <a href={item.link} target="_blank" rel="noopener noreferrer" class="sticker card">
            <img class="card__image" src={item.image || '/wire-placeholder.svg'} alt="" loading="lazy" />
            <div class="card__body">
              <span class="source">
                {faviconUrl(item.link) && <img class="source__logo" src={faviconUrl(item.link)} alt="" width="16" height="16" loading="lazy" />}
                <span class="eyebrow">{item.source}</span>
              </span>
              <h2>{item.title}</h2>
              <p>{item.summary}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .page { padding: 48px 24px 80px; }
  h1 { font-size: 36px; margin-bottom: 14px; }
  .intro { color: var(--slate); margin-bottom: 36px; }
  .intro .byline { display: block; margin-top: 6px; }
  .list { list-style: none; margin: 0; padding: 0; display: grid; gap: 24px; }
  .list li { margin: 0; min-width: 0; }
  .card { display: flex; gap: 20px; padding: 22px; align-items: flex-start; min-width: 0; }
  .card__image {
    width: 140px;
    height: 100px;
    object-fit: cover;
    border-radius: 10px;
    border: 2px solid var(--ink);
    flex-shrink: 0;
  }
  .card__body { flex: 1; min-width: 0; }
  .source { display: inline-flex; align-items: center; gap: 8px; }
  .source__logo { border-radius: 4px; }
  .list h2 { font-size: 20px; margin: 12px 0 8px; overflow-wrap: anywhere; }
  .list p { color: var(--slate); margin: 0; font-size: 15px; overflow-wrap: anywhere; }

  @media (max-width: 560px) {
    .card { flex-direction: column; }
    .card__image { width: 100%; height: 160px; }
  }
</style>
